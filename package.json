{
  "name": "instagram-mcp-ai",
  "version": "0.0.1",
  "description": "MCP server for the Instagram Platform (Meta Graph API) — professional-account tools.",
  "mcpName": "io.github.IvanBBaev/instagram-mcp-ai",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "instagram-mcp-ai": "bin/instagram-mcp-ai.cjs"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "bin/",
    "server.json",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "author": "Ivan Baev <ivanbbaev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IvanBBaev/instagram-mcp.git"
  },
  "homepage": "https://ivanbbaev.github.io/instagram-mcp/",
  "bugs": {
    "url": "https://github.com/IvanBBaev/instagram-mcp/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test \"dist/**/*.test.js\"",
    "test:full": "npm run build && npm test",
    "coverage": "c8 --reporter=text --reporter=lcov npm test",
    "gen:readme": "npm run build && node scripts/gen-readme.mjs",
    "check": "npm run lint && npm run format:check && npm run build && npm test",
    "prepublishOnly": "npm run check"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^26.1.1",
    "c8": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "fast-check": "^3.20.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "instagram",
    "meta",
    "graph-api",
    "instagram-api",
    "social-media",
    "llm",
    "ai"
  ],
  "trademark": "instagram-mcp-ai is an independent, community-built project and is not affiliated with, endorsed by, or sponsored by Meta Platforms, Inc. Instagram and Meta are trademarks of Meta Platforms, Inc., used here only nominatively to indicate compatibility."
}
